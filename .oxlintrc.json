{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    ".claude",
    "packages/jsdbc/src/prisma/__tests__/generated/**"
  ],
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "node",
    "vitest"
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "require-mock-type-parameters": "off",
    "expect-expect": "off",
    "typescript/consistent-type-imports": [
      "error",
      {
        "prefer": "type-imports",
        "fixStyle": "inline-type-imports",
        "disallowTypeAnnotations": true
      }
    ],
    "typescript/no-import-type-side-effects": "error"
  },
  "env": {
    "builtin": true,
    "node": true
  },
  "overrides": [
    {
      "files": ["**/*it-shared.ts"],
      "rules": {
        "no-standalone-expect": "off"
      }
    }
  ]
}
