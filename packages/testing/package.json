{
  "name": "@nestjs-port/testing",
  "version": "0.1.0",
  "private": false,
  "description": "Testing utilities for NestJS Port",
  "keywords": [
    "ai",
    "nestjs",
    "testing"
  ],
  "homepage": "https://nestjs-port.github.io/nestjs-port-commons",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-port-commons",
    "directory": "packages/testing"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run",
    "jsr:check": "node ../../scripts/publish-jsr.mjs --dry-run --allow-dirty",
    "jsr:publish": "node ../../scripts/publish-jsr.mjs --allow-dirty"
  },
  "devDependencies": {
    "@nestjs-port/core": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs-port/core": "^0.1.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
