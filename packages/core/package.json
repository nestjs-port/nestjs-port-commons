{
  "name": "@nestjs-port/core",
  "version": "0.0.3",
  "private": false,
  "description": "Shared primitives and utilities for NestJS Port",
  "keywords": [
    "ai",
    "core",
    "nestjs"
  ],
  "homepage": "https://nestjs-port.github.io/nestjs-port-commons",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
