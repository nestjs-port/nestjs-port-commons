{
  "name": "@nestjs-port/jsdbc",
  "version": "0.0.1",
  "private": false,
  "description": "JDBC integration",
  "homepage": "https://nestjs-port.github.io/nestjs-port-commons",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-port-commons",
    "directory": "packages/jsdbc"
  },
  "keywords": [
    "nestjs",
    "ai",
    "jsdbc"
  ],
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    },
    "./typeorm": {
      "types": "./dist/typeorm/index.d.ts",
      "require": "./dist/typeorm/index.js"
    },
    "./mikroorm": {
      "types": "./dist/mikroorm/index.d.ts",
      "require": "./dist/mikroorm/index.js"
    },
    "./sequelize": {
      "types": "./dist/sequelize/index.d.ts",
      "require": "./dist/sequelize/index.js"
    },
    "./prisma": {
      "types": "./dist/prisma/index.d.ts",
      "require": "./dist/prisma/index.js"
    },
    "./drizzle": {
      "types": "./dist/drizzle/index.d.ts",
      "require": "./dist/drizzle/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "pretypecheck": "pnpm prisma:generate",
    "pretest": "pnpm prisma:generate",
    "prisma:generate": "DATABASE_URL=postgresql://jsdbc:jsdbc@localhost:5432/jsdbc_integration pnpm exec prisma generate --schema src/prisma/__tests__/schema.prisma",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@mikro-orm/core": "^7.0.0",
    "@nestjs-port/core": "workspace:*",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/sequelize": "^11.0.0",
    "@nestjs/typeorm": "^10.0.0 || ^11.0.0",
    "@prisma/client": "^6.18.0",
    "class-transformer": "^0.4.0 || ^0.5.0",
    "drizzle-orm": "^0.45.0",
    "sequelize": "^6.37.0",
    "typeorm": "^0.3.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/sequelize": {
      "optional": true
    },
    "@mikro-orm/core": {
      "optional": true
    },
    "@nestjs/typeorm": {
      "optional": true
    },
    "@prisma/client": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "class-transformer": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "sequelize": {
      "optional": true
    },
    "typeorm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mikro-orm/core": "^7.0.10",
    "@mikro-orm/nestjs": "^7.0.1",
    "@mikro-orm/postgresql": "^7.0.11",
    "@nestjs-port/core": "workspace:*",
    "@nestjs/common": "^11.1.11",
    "@nestjs/core": "^11.1.19",
    "@nestjs/sequelize": "^11.0.1",
    "@nestjs/testing": "^11.1.19",
    "@nestjs/typeorm": "^11.0.1",
    "@prisma/client": "^6.18.0",
    "@testcontainers/postgresql": "^11.14.0",
    "class-transformer": "^0.5.1",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "prisma": "^6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sequelize": "^6.37.7",
    "testcontainers": "^11.14.0",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ]
}
