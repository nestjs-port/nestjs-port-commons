{
  "name": "@nestjs-port/observation",
  "version": "0.1.0",
  "private": false,
  "description": "OpenTelemetry observation support for NestJS Port",
  "keywords": [
    "ai",
    "nestjs",
    "observation"
  ],
  "homepage": "https://nestjs-port.github.io/nestjs-port-commons",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-port-commons",
    "directory": "packages/observation"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run",
    "jsr:check": "jsr publish --dry-run --allow-dirty",
    "jsr:publish": "node ../../scripts/publish-jsr.mjs --allow-dirty"
  },
  "devDependencies": {
    "@nestjs-port/core": "workspace:*",
    "@nestjs/common": "^11.1.11",
    "@nestjs/testing": "^11.1.11",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@nestjs-port/core": "^0.1.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@opentelemetry/api": "^1.9.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
