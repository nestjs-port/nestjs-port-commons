{
  "name": "nestjs-port-commons",
  "version": "0.0.0",
  "private": true,
  "description": "NestJS port commons workspace",
  "license": "Apache-2.0",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "turbo run test",
    "clean": "turbo run clean --force && rimraf .turbo",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=main",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "*": "biome check --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "rimraf": "^6.1.3",
    "turbo": "^2.8.9",
    "typescript": "^6.0.2",
    "vitest": "^4.0.16"
  }
}
